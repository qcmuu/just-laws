# Copy to .env and fill in. All values overridable via environment.

# --- LLM (generation), any OpenAI-compatible endpoint ---
LLM_BASE_URL=https://token.sensenova.cn/v1
LLM_MODEL=sensenova-6.7-flash-lite
LLM_API_KEY=your-key-here

# --- Embedding ---
# backend: "local" (default, no API key) or "api" (OpenAI-compatible)
EMBEDDING_BACKEND=local
EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5
# Only used when EMBEDDING_BACKEND=api :
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_API_KEY=your-key-here

# --- misc ---
SITE_BASE_URL=https://www.justlaws.cn
TOP_K=8
