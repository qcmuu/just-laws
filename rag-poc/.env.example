# Copy to .env and fill in. All values overridable via environment.

# --- LLM (generation), any OpenAI-compatible endpoint ---
LLM_BASE_URL=https://token.sensenova.cn/v1
LLM_MODEL=sensenova-6.7-flash-lite
LLM_API_KEY=your-key-here

# --- Embedding ---
# backend: "local" (default, no API key) or "api" (OpenAI-compatible)
EMBEDDING_BACKEND=local
EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5
# Only used when EMBEDDING_BACKEND=api :
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_API_KEY=your-key-here

# --- vector store ---
# VECTOR_BACKEND: "pgvector" (default, production) or "chroma" (self-contained demo)
VECTOR_BACKEND=pgvector
# pgvector: default matches docker-compose.yml (host port 5433). In production
# point this at your managed Postgres. Never hardcode credentials in code.
DATABASE_URL=postgresql://justlaws:justlaws@localhost:5433/justlaws
# PG_TABLE=law_chunks
# Index type for the vector column: ivfflat (default) or hnsw
# PG_INDEX_TYPE=ivfflat
# Must match the embedding model's output dim (bge-small-zh-v1.5 -> 512)
EMBEDDING_DIM=512

# --- retrieval (hybrid: dense vector + BM25 lexical, fused then reranked) ---
# RETRIEVAL_MODE: "hybrid" (default) or "vector" (legacy dense-only)
RETRIEVAL_MODE=hybrid
# candidates each retriever feeds into fusion
FUSION_CANDIDATES=50
# FUSION_METHOD: "rrf" (default) or "weighted"
FUSION_METHOD=rrf
RRF_K=60
DENSE_WEIGHT=1.0
SPARSE_WEIGHT=1.0

# --- rerank (cross-encoder over fused candidates) ---
RERANK_ENABLED=true
# RERANK_BACKEND: "local" (default, no key) or "api" (Jina/SiliconFlow /rerank)
RERANK_BACKEND=local
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_CANDIDATES=30
# Only used when RERANK_BACKEND=api :
# RERANK_BASE_URL=https://api.siliconflow.cn/v1
# RERANK_API_KEY=your-key-here

# --- backend / CORS ---
# Comma-separated allowed origins; "*" allows any (fine for local dev).
CORS_ALLOW_ORIGINS=*

# --- misc ---
SITE_BASE_URL=https://www.justlaws.cn
TOP_K=8
